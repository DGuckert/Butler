# Copy this file to .env and fill in your own values.

# Absolute or relative path to the folder where downloaded songs are stored.
# Defaults to ./music if unset.
MUSIC_DIR=

# Random secret used to sign JWT auth tokens. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=changeme

# SQLite database file for users/library data.
DATABASE_URL=butler.db

# Optional: Spotify integration (playlist import). Leave blank to disable.
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match a Redirect URI registered in your Spotify app, with
# /spotify/auth/callback appended, e.g. http://localhost:8080/spotify/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/spotify/callback

