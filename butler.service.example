[Unit]
Description=Butler Music Server
After=network.target

[Service]
Type=simple
User=butler
WorkingDirectory=/opt/butler
Environment="PATH=/home/butler/.local/bin:/usr/bin:/bin"
ExecStart=/home/butler/.local/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
